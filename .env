# Security
API_KEY=your_secret_api_key_here
DEV_MODE=false

# Application
APP_NAME="XAIT Approval Decision Engine"
ENVIRONMENT=development
LOG_LEVEL=INFO

# Database
DATABASE_URL=sqlite:///./data/decision_engine.db

# Config Files
RULES_CONFIG_PATH=config/rules.yaml
APP_CONFIG_PATH=config/app.yaml
EMAIL_TEMPLATES_PATH=config/email_templates.yaml

# Jobs (Email)
SMTP_HOST=mock
SMTP_PORT=587
SMTP_USER=test
SMTP_PASSWORD=test
EMAIL_FROM=approvals@example.com
